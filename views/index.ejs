<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= site_name %> - <%= dict.hero_title %></title>
  <meta name="description" content="<%= dict.hero_subtitle %>">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --primary-color: <%= theme.primary_color %>;
      --primary-hover: <%= theme.primary_hover %>;
      --secondary-color: <%= theme.secondary_color %>;
      --accent-color: <%= theme.accent_color %>;
      --bg-color: <%= theme.bg_color %>;
      --surface-color: <%= theme.surface_color %>;
      --text-main: <%= theme.text_main %>;
      --text-muted: <%= theme.text_muted %>;
    }
  </style>
</head>
<body>

  <!-- Full-Screen Onboarding Slides Overlay -->
  <div class="onboarding-overlay" id="onboarding-overlay" style="display: none;">
    <div class="onboarding-viewport">
      <button class="onboarding-skip-btn" onclick="finishOnboarding()"><%= dict.onboarding_skip %> <i class="fa-solid fa-angles-right"></i></button>
      
      <div class="onboarding-slides" id="onboarding-slides">
        <!-- Slide 1: Welcome/Splash -->
        <div class="onboarding-slide" style="background-color: #EAE6F8; justify-content: center; align-items: center; text-align: center; padding: 40px;">
          <div style="background-color: #fff; width: 100px; height: 100px; border-radius: 28px; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 25px rgba(140,98,255,0.15); margin-bottom: 24px;">
            <span style="font-family: var(--font-heading); font-weight: 800; font-size: 48px; color: var(--primary-color);">S</span>
          </div>
          <h1 style="font-size: 38px; margin-bottom: 12px; font-family: var(--font-heading); font-weight: 800;"><%= site_name %></h1>
          <p style="font-size: 15px; color: var(--text-muted); max-width: 280px; margin-bottom: 40px;"><%= dict.onboarding_welcome_desc %></p>
          <button class="btn btn-accent" style="width: 100%; max-width: 280px;" onclick="nextSlide(1)"><%= dict.onboarding_btn_start %></button>
        </div>

        <!-- Slide 2: Weather Alerts -->
        <div class="onboarding-slide">
          <div class="slide-image-section" style="background-image: url('<%= media.onboarding_weather %>');">
            <div class="slide-image-overlay"></div>
          </div>
          <div class="onboarding-card">
            <div class="onboarding-dots">
              <span class="onboarding-dot"></span>
              <span class="onboarding-dot active"></span>
              <span class="onboarding-dot"></span>
              <span class="onboarding-dot"></span>
              <span class="onboarding-dot"></span>
            </div>
            <h2 class="onboarding-title"><%= dict.onboarding_weather_title %></h2>
            <p class="onboarding-desc"><%= dict.onboarding_weather_desc %></p>
            <div class="onboarding-btn-row">
              <button class="btn btn-primary" onclick="nextSlide(2)"><%= dict.onboarding_next %> <i class="fa-solid fa-arrow-right" style="margin-left: 6px;"></i></button>
            </div>
          </div>
        </div>

        <!-- Slide 3: Crop Recommendation -->
        <div class="onboarding-slide">
          <div class="slide-image-section" style="background-image: url('<%= media.onboarding_crops %>');">
            <div class="slide-image-overlay"></div>
          </div>
          <div class="onboarding-card">
            <div class="onboarding-dots">
              <span class="onboarding-dot"></span>
              <span class="onboarding-dot"></span>
              <span class="onboarding-dot active"></span>
              <span class="onboarding-dot"></span>
              <span class="onboarding-dot"></span>
            </div>
            <h2 class="onboarding-title"><%= dict.onboarding_crops_title %></h2>
            <p class="onboarding-desc"><%= dict.onboarding_crops_desc %></p>
            <div class="onboarding-btn-row">
              <button class="btn btn-primary" onclick="nextSlide(3)"><%= dict.onboarding_next %> <i class="fa-solid fa-arrow-right" style="margin-left: 6px;"></i></button>
            </div>
          </div>
        </div>

        <!-- Slide 4: Soil Health & Yield -->
        <div class="onboarding-slide">
          <div class="slide-image-section" style="background-image: url('<%= media.onboarding_soil %>');">
            <div class="slide-image-overlay"></div>
          </div>
          <div class="onboarding-card">
            <div class="onboarding-dots">
              <span class="onboarding-dot"></span>
              <span class="onboarding-dot"></span>
              <span class="onboarding-dot"></span>
              <span class="onboarding-dot active"></span>
              <span class="onboarding-dot"></span>
            </div>
            <h2 class="onboarding-title"><%= dict.onboarding_soil_title %></h2>
            <p class="onboarding-desc"><%= dict.onboarding_soil_desc %></p>
            <div class="onboarding-btn-row">
              <button class="btn btn-primary" onclick="nextSlide(4)"><%= dict.onboarding_next %> <i class="fa-solid fa-arrow-right" style="margin-left: 6px;"></i></button>
            </div>
          </div>
        </div>

        <!-- Slide 5: Let's Start -->
        <div class="onboarding-slide">
          <div class="slide-image-section" style="background-image: url('<%= media.onboarding_welcome %>');">
            <div class="slide-image-overlay"></div>
          </div>
          <div class="onboarding-card">
            <div class="onboarding-dots">
              <span class="onboarding-dot"></span>
              <span class="onboarding-dot"></span>
              <span class="onboarding-dot"></span>
              <span class="onboarding-dot"></span>
              <span class="onboarding-dot active"></span>
            </div>
            <h2 class="onboarding-title">Start Growing Smarter!</h2>
            <p class="onboarding-desc">Register your farm layout to receive customized alerts, or sign in to your dashboard.</p>
            <div class="onboarding-btn-row">
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; width: 100%;">
                <button class="btn btn-primary" onclick="finishOnboarding('login')"><%= dict.onboarding_btn_login %></button>
                <button class="btn btn-accent" onclick="finishOnboarding('register')"><%= dict.onboarding_btn_register %></button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Gateway Auth Overlay (Lock Screen for returning users) -->
  <div class="modal-overlay active" id="gateway-auth-overlay" style="display: none; background: linear-gradient(135deg, rgba(26,87,24,0.1) 0%, rgba(0,0,0,0.85) 100%); z-index: 1800; overflow-y: auto;">
    <div class="modal-card" style="width: 90%; max-width: 440px; margin: 40px auto; pointer-events: auto;">
      <!-- Logo header -->
      <div style="text-align: center; margin-bottom: 24px;">
        <div style="background: linear-gradient(135deg, var(--primary-color), var(--secondary-color)); width: 56px; height: 56px; border-radius: 16px; display: inline-flex; align-items: center; justify-content: center; color: #fff; font-weight: 800; font-size: 28px; margin-bottom: 12px;">S</div>
        <h2 style="font-size: 24px; font-family: var(--font-heading);"><%= site_name %> Gateway</h2>
        <p style="font-size: 13.5px; color: var(--text-muted); margin-top: 4px;">Sign in or create a profile to access agricultural advice.</p>
      </div>

      <!-- Gateway error messages -->
      <div id="gateway-error" class="admin-alert" style="background-color: #F8D7DA; color: #721C24; border: 1px solid #F5C6CB; margin-bottom: 20px; font-size: 13.5px; display: none;"></div>

      <!-- Tabs header -->
      <div style="display: flex; background-color: rgba(0,0,0,0.03); padding: 4px; border-radius: 20px; gap: 4px; margin-bottom: 24px;">
        <button id="gt-tab-login" onclick="switchGatewayTab('login')" style="flex: 1; border: none; background: var(--surface-color); color: var(--primary-color); font-weight: 700; padding: 8px; border-radius: 16px; cursor: pointer; box-shadow: var(--shadow-sm);">Log In</button>
        <button id="gt-tab-register" onclick="switchGatewayTab('register')" style="flex: 1; border: none; background: transparent; color: var(--text-muted); font-weight: 700; padding: 8px; border-radius: 16px; cursor: pointer;">Register Farm</button>
      </div>

      <!-- Log In Form panel -->
      <div id="gt-panel-login">
        <form id="gateway-login-form" onsubmit="handleGatewayLogin(event)">
          <div class="form-group">
            <label id="gt-label-username">Farmer's Full Name</label>
            <input type="text" id="gt-login-username" class="form-control" placeholder="e.g. Bamidele Alao" required>
          </div>
          <div class="form-group">
            <label id="gt-label-credential">Password / Phone Number</label>
            <div class="password-field-wrapper">
              <input type="password" id="gt-login-credential" class="form-control" placeholder="Enter password or phone number" required>
              <button type="button" class="password-toggle-eye" onclick="togglePasswordVisibility('gt-login-credential')">
                <i class="fa-solid fa-eye" id="gt-login-credential-eye"></i>
              </button>
            </div>
          </div>
          <button type="submit" class="btn btn-primary" style="width: 100%; margin-bottom: 16px;">Access My Dashboard</button>
      </div>

      <!-- Register Form panel -->
      <div id="gt-panel-register" style="display: none;">
        <form id="gateway-register-form" onsubmit="handleGatewayRegister(event)">
          <div class="form-group">
            <label><%= dict.label_farmer_name %></label>
            <input type="text" id="gt-reg-name" class="form-control" placeholder="e.g. Baba Tunde" required>
          </div>
          <div class="form-group">
            <label><%= dict.label_farmer_location %></label>
            <input type="text" id="gt-reg-location" class="form-control" placeholder="e.g. Ibadan, Oyo" required>
          </div>
          <div style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 12px;">
            <div class="form-group">
              <label><%= dict.label_farmer_size %></label>
              <input type="number" id="gt-reg-size" class="form-control" placeholder="Hectares" min="0.1" step="0.1" required>
            </div>
            <div class="form-group">
              <label><%= dict.label_farmer_phone %></label>
              <input type="tel" id="gt-reg-phone" class="form-control" placeholder="e.g. 08031234567" required>
            </div>
          </div>
          <div class="form-group">
            <label>Set Password</label>
            <input type="password" id="gt-reg-password" class="form-control" placeholder="Create a secure password" required>
          </div>
          <div class="form-group">
            <label><%= dict.label_farmer_email %></label>
            <input type="email" id="gt-reg-email" class="form-control" placeholder="e.g. name@domain.com">
          </div>
          <button type="submit" class="btn btn-accent" style="width: 100%;">Create Farm Account</button>
        </form>
      </div>

      <!-- Success State -->
      <div id="gt-panel-success" style="display: none; text-align: center;">
        <div class="success-check-badge">🎉</div>
        <h3 style="font-size: 22px; margin-bottom: 8px;">Registration Successful!</h3>
        <p style="font-size: 13.5px; color: var(--text-muted); margin-bottom: 24px;">Welcome to Seedorra! You can now log in to access your dashboard.</p>
        <button class="btn btn-primary" style="width: 100%;" onclick="switchGatewayTab('login')">Log In Now</button>
      </div>

    </div>
  </div>

  <!-- Extended Farmer Dashboard Modal Portal -->
  <div class="farmer-dashboard-overlay" id="farmer-dashboard-overlay">
    <div class="farmer-dashboard-card">
      
      <!-- Dashboard Tab Header -->
      <div class="fd-header">
        <div style="display: flex; align-items: center; gap: 16px;">
          <div class="profile-avatar-uploader" style="width: 48px; height: 48px; margin: 0; border-width: 2px;" onclick="triggerPhotoUpload()">
            <img id="fd-header-avatar" src="/images/onboarding_welcome.jpg" alt="Avatar">
            <div class="profile-avatar-hover" style="font-size: 8px;"><i class="fa-solid fa-camera"></i></div>
          </div>
          <div>
            <h3 style="font-size: 18px; line-height: 1.2;" id="fd-welcome-title">Bamidele Alao</h3>
            <p style="font-size: 12px; color: var(--text-muted);"><i class="fa-solid fa-location-dot" style="margin-right: 4px; color: var(--secondary-color);"></i><span id="fd-location">Ogbomosho, Oyo</span></p>
          </div>
        </div>
        
        <ul class="fd-nav-tabs">
          <li class="fd-tab-item active" id="tab-feed"><button onclick="switchTab('feed')"><i class="fa-solid fa-house" style="margin-right: 6px;"></i>Feed</button></li>
          <li class="fd-tab-item" id="tab-diag"><button onclick="switchTab('diag')"><i class="fa-solid fa-kit-medical" style="margin-right: 6px;"></i>Diagnose</button></li>
          <li class="fd-tab-item" id="tab-pest"><button onclick="switchTab('pest')"><i class="fa-solid fa-bug" style="margin-right: 6px;"></i>Pest Alerts</button></li>
          <li class="fd-tab-item" id="tab-profile"><button onclick="switchTab('profile')"><i class="fa-solid fa-circle-user" style="margin-right: 6px;"></i>Profile & Badges</button></li>
          <li class="fd-tab-item" id="tab-help"><button onclick="switchTab('help')"><i class="fa-solid fa-circle-info" style="margin-right: 6px;"></i>Help Desk</button></li>
        </ul>

        <button class="btn btn-secondary" style="padding: 6px 12px; font-size: 12px;" onclick="logoutFarmer()"><i class="fa-solid fa-right-from-bracket" style="margin-right: 4px;"></i>Log Out</button>
      </div>

      <!-- Dashboard Content Viewport -->
      <div class="fd-body">
        
        <!-- PANEL 1: MY FARM FEED -->
        <div class="fd-panel active" id="panel-feed">
          <!-- Photo News Slideshow Session -->
          <div class="news-slider-container">
            <div class="news-slides" id="news-slides">
              <div class="news-slide active" style="background-image: url('/images/news_harvest.jpg');">
                <div class="news-caption-overlay">
                  <span style="background-color: var(--secondary-color); padding: 4px 8px; border-radius: 4px; font-size: 10px; font-weight: 700; margin-bottom: 6px; display: inline-block;">FARM HARVEST STORY</span>
                  <h4 style="font-size: 16px; font-weight: 700;">Cooperative Farm Bumper Harvest in Oyo State</h4>
                  <p style="font-size: 13px; opacity: 0.9;">Farmers report a 15% increase in Yam yield using Seedorra planting windows.</p>
                </div>
              </div>
              <div class="news-slide" style="background-image: url('/images/news_irrigation.jpg');">
                <div class="news-caption-overlay">
                  <span style="background-color: var(--accent-color); padding: 4px 8px; border-radius: 4px; font-size: 10px; font-weight: 700; margin-bottom: 6px; display: inline-block;">TECHNOLOGY UPDATE</span>
                  <h4 style="font-size: 16px; font-weight: 700;">Solar Drip Irrigation Installations Spread in North</h4>
                  <p style="font-size: 13px; opacity: 0.9;">New low-cost solar sprinkler rigs deployed to combat local dry spells.</p>
                </div>
              </div>
              <div class="news-slide" style="background-image: url('/images/onboarding_welcome.jpg');">
                <div class="news-caption-overlay">
                  <span style="background-color: var(--primary-color); padding: 4px 8px; border-radius: 4px; font-size: 10px; font-weight: 700; margin-bottom: 6px; display: inline-block;">COMMUNITY LAUNCH</span>
                  <h4 style="font-size: 16px; font-weight: 700;">Seedorra Offline SMS Reaches 10,000 Smallholders</h4>
                  <p style="font-size: 13px; opacity: 0.9;">Agronomy tips delivered in Hausa, Yoruba, and Igbo daily to basic keypad phones.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="farmer-stat-grid">
            <div class="farmer-stat-item">
              <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px;">My Farm Size</div>
              <div style="font-size: 20px; font-weight: 800; color: var(--primary-color);"><span id="fd-size">0.0</span> Hectares</div>
            </div>
            <div class="farmer-stat-item">
              <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px;">Pest Warning Alerts</div>
              <div style="font-size: 20px; font-weight: 800; color: #DC3545;" id="fd-pest-warning-count">Active Alerts</div>
            </div>
            <div class="farmer-stat-item" style="background-color: rgba(140, 98, 255, 0.08);">
              <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px;">Weekly Usage Badges</div>
              <div style="font-size: 18px; font-weight: 800; color: var(--accent-color);" id="fd-badges-unlocked-count">1 Unlocked</div>
            </div>
          </div>

          <div class="fd-feed-grid">
            <div style="border: 1px solid var(--border-color); border-radius: var(--border-radius-md); padding: 20px; background-color: var(--bg-color);">
              <h4 style="font-size: 15px; margin-bottom: 12px; color: var(--primary-color);"><i class="fa-solid fa-cloud-sun-rain" style="margin-right: 8px;"></i>Live Climate Threat Alert</h4>
              <div id="fd-weather-desc" style="font-size: 14px; margin-bottom: 12px; font-weight: 600;">Loading status...</div>
              <div style="font-size: 13px; color: var(--text-muted);" id="fd-weather-forecast">Forecast details...</div>
            </div>
            <div style="border: 1px solid var(--border-color); border-radius: var(--border-radius-md); padding: 20px; background-color: var(--bg-color);">
              <h4 style="font-size: 15px; margin-bottom: 12px; color: var(--accent-color);"><i class="fa-solid fa-seedling" style="margin-right: 8px;"></i>Suggested Seeds</h4>
              <div id="fd-crops-list" style="font-size: 14px; line-height: 1.5; font-weight: 600;">Loading...</div>
            </div>
          </div>
        </div>

        <!-- PANEL 2: DIAGNOSE PLANT -->
        <div class="fd-panel" id="panel-diag">
          <h3 style="margin-bottom: 8px;">AI Plant Disease Diagnoser</h3>
          <p style="font-size: 14px; color: var(--text-muted); margin-bottom: 24px;">Upload a photo of your leaf or crop. The AI matches it against an agricultural library of diseases and verified cases to return a cure.</p>

          <form id="diag-form" onsubmit="handlePlantDiagnosis(event)">
            <div class="form-group">
              <label>Select Crop Category</label>
              <select class="form-control" id="diag-crop" required>
                <option value="maize">Maize (Corn)</option>
                <option value="cassava">Cassava (Rogo)</option>
                <option value="tomato">Tomato (Tomati)</option>
                <option value="other">Other Plant / Cereal</option>
              </select>
            </div>

            <!-- Drag & Drop Upload Zone -->
            <div class="diag-upload-zone" onclick="document.getElementById('diag-file').click()">
              <i class="fa-solid fa-circle-up" style="font-size: 36px; color: var(--accent-color); margin-bottom: 12px;"></i>
              <h4 style="font-size: 15px;">Tap to select or take leaf picture</h4>
              <p style="font-size: 12px; color: var(--text-muted); margin-top: 4px;">PNG, JPG supported (Max 5MB)</p>
              <input type="file" id="diag-file" style="display: none;" accept="image/*" onchange="previewDiagImage(this)" required>
            </div>

            <!-- Upload Preview -->
            <div id="diag-preview-container" style="display: none; text-align: center; margin-bottom: 20px;">
              <img id="diag-preview-img" src="#" style="max-height: 160px; border-radius: var(--border-radius-sm); border: 1px solid var(--border-color); object-fit: cover;">
              <div style="margin-top: 8px;"><button type="button" class="btn btn-secondary" style="padding: 4px 12px; font-size: 12px;" onclick="cancelDiagUpload()">Remove</button></div>
            </div>

            <!-- Scan progress meter -->
            <div class="diag-progress-bar-container" id="diag-progress-container">
              <div class="diag-progress-bar" id="diag-progress"></div>
            </div>
            <div id="diag-scan-status" style="font-size: 13px; font-weight: 700; color: var(--accent-color); text-align: center; display: none; margin-bottom: 20px;">Scanning verified database...</div>

            <button type="submit" class="btn btn-accent" style="width: 100%;">Analyze Crop Health</button>
          </form>

          <!-- Diagnostic Results Card -->
          <div class="results-box" id="diag-results" style="display: none; margin-top: 32px; padding: 24px; border: 1px solid var(--accent-color); background-color: rgba(140, 98, 255, 0.02);">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(140, 98, 255, 0.15); padding-bottom: 12px; margin-bottom: 20px;">
              <h4 style="color: var(--accent-color); font-size: 18px;"><i class="fa-solid fa-square-check" style="margin-right: 8px;"></i>AI Diagnostics Analysis</h4>
              <span class="trend-badge trend-up" id="diag-match-score">96% Match</span>
            </div>

            <div class="diag-results-split">
              <!-- Uploaded leaf vs matched case -->
              <div class="diag-image-box">
                <div style="font-size: 11px; font-weight: 700; margin-bottom: 6px; color: var(--text-muted);">YOUR UPLOADED LEAF</div>
                <img id="diag-res-user-img" src="#" alt="User Upload">
              </div>
              <div class="diag-image-box" style="border-left: 1px solid rgba(0,0,0,0.06);">
                <div style="font-size: 11px; font-weight: 700; margin-bottom: 6px; color: var(--text-muted);">AGRICULTURAL LIBRARY MATCH</div>
                <img id="diag-res-match-img" src="/images/disease_blight.jpg" alt="Library Match">
              </div>
            </div>

            <div style="margin-top: 24px; display: grid; gap: 16px;">
              <div>
                <strong style="font-size: 13px; color: var(--text-muted); display: block; margin-bottom: 4px;">DETECTED PATHOGEN</strong>
                <span id="diag-res-pathogen" style="font-size: 16px; font-weight: 800; color: #DC3545;">Maize Common Rust</span>
              </div>
              <div>
                <strong style="font-size: 13px; color: var(--text-muted); display: block; margin-bottom: 4px;">DAMAGE SEVERITY</strong>
                <span class="trend-badge" style="background-color: rgba(220, 53, 69, 0.15); color: #dc3545;" id="diag-res-severity">High</span>
              </div>
              <div>
                <strong style="font-size: 13px; color: var(--text-muted); display: block; margin-bottom: 4px;">VERIFIED CURE TREATMENT</strong>
                <p id="diag-res-treatment" style="font-size: 14.5px; line-height: 1.5; color: var(--text-main); font-weight: 500;">Clear resid.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- PANEL 3: PEST ALERTS -->
        <div class="fd-panel" id="panel-pest">
          <h3 style="margin-bottom: 8px;">National Pest & Bug Alerts</h3>
          <p style="font-size: 14px; color: var(--text-muted); margin-bottom: 24px;">Live warnings on insect swarms and caterpillar infestations compiled from regional agricultural extensions.</p>

          <div id="pest-alerts-feed-list">
            <% pestAlerts.forEach(alert => { %>
              <div class="pest-warning-card <%= alert.severity === 'extreme' ? 'extreme' : '' %>">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                  <h4 style="font-size: 16px; color: #721C24;"><i class="fa-solid fa-circle-exclamation" style="margin-right: 8px;"></i><%= alert.pest %></h4>
                  <span class="trend-badge <%= alert.severity === 'extreme' ? 'trend-down' : 'trend-neutral' %>" style="text-transform: uppercase;"><%= alert.severity %></span>
                </div>
                <div style="font-size: 13.5px; margin-bottom: 12px;">
                  <strong>AFFECTED REGIONS:</strong> <span style="color: var(--primary-color); font-weight: 700;"><%= alert.location %></span>
                </div>
                <p style="font-size: 14px; margin-bottom: 16px;"><%= alert.description %></p>
                <div style="background-color: rgba(255,255,255,0.7); border-radius: var(--border-radius-sm); padding: 12px 16px; font-size: 13.5px; border: 1px dashed rgba(0,0,0,0.1);">
                  <strong>PREVENTION REMEDY:</strong> <%= alert.remedy %>
                </div>
              </div>
