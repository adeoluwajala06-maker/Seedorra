    </footer>
  </div>

  <script>
    // Language selection
    function changeLanguage(val) {
      window.location.href = `/?lang=${val}`;
    }

    function toggleMobileMenu() {
      const menu = document.getElementById('nav-menu');
      menu.classList.toggle('mobile-active');
    }

    // Weather warning alert update
    const weatherData = <%- JSON.stringify(weatherData) %>;
    function updateWeather(region) {
      const w = weatherData[region];
      document.getElementById('weather-temp').textContent = w.temp;
      document.getElementById('detail-temp').textContent = w.temp;
      document.getElementById('detail-humidity').textContent = w.humidity;
      document.getElementById('detail-wind').textContent = w.wind;
      document.getElementById('weather-forecast').textContent = w.forecast;
      document.getElementById('weather-alert-message').textContent = w.alert;
      
      const alertCard = document.getElementById('weather-alert-card');
      if (w.severity === 'severe') {
        alertCard.className = 'alert-box alert-severe';
      } else {
        alertCard.className = 'alert-box';
      }
      
      const icon = document.getElementById('weather-icon');
      if (region === 'NW' || region === 'NE') {
        icon.className = 'fa-solid fa-sun';
        icon.style.color = '#FFC107';
      } else {
        icon.className = 'fa-solid fa-cloud-showers-heavy';
        icon.style.color = 'var(--primary-color)';
      }
    }
    updateWeather('SW');

    // --- Onboarding auto slide deck transitions ---
    let currentOnboardingSlide = 0;
    let onboardingTimer = null;

    function startOnboardingTimer() {
      stopOnboardingTimer();
      onboardingTimer = setInterval(() => {
        let nextIdx = (currentOnboardingSlide + 1) % 5;
        nextSlide(nextIdx);
      }, 10000); 
    }

    function stopOnboardingTimer() {
      if (onboardingTimer) {
        clearInterval(onboardingTimer);
        onboardingTimer = null;
      }
    }

    function nextSlide(currentIndex) {
      currentOnboardingSlide = currentIndex;
      const slidesContainer = document.getElementById('onboarding-slides');
      const offset = currentOnboardingSlide * -20;
      slidesContainer.style.transform = `translateX(${offset}%)`;
      startOnboardingTimer();
    }

    // IP-based onboarding completion controller
    function finishOnboarding(targetTab) {
      stopOnboardingTimer();
      document.getElementById('onboarding-overlay').style.display = 'none';
      
      fetch('/api/onboarding/complete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      })
      .then(res => res.json())
      .then(data => {
        document.getElementById('gateway-auth-overlay').style.display = 'flex';
        if (targetTab) {
          switchGatewayTab(targetTab);
        } else {
          switchGatewayTab('login');
        }
      });
    }

    // --- Gateway Authentication Form Screen controls ---

    function switchGatewayTab(tab) {
      const btnLogin = document.getElementById('gt-tab-login');
      const btnReg = document.getElementById('gt-tab-register');
      const pnlLogin = document.getElementById('gt-panel-login');
      const pnlReg = document.getElementById('gt-panel-register');
      const pnlSuccess = document.getElementById('gt-panel-success');

      document.getElementById('gateway-error').style.display = 'none';

      if (tab === 'login') {
        btnLogin.style.backgroundColor = "var(--surface-color)";
        btnLogin.style.color = "var(--primary-color)";
        btnLogin.style.boxShadow = "var(--shadow-sm)";
        btnReg.style.backgroundColor = "transparent";
        btnReg.style.color = "var(--text-muted)";
        btnReg.style.boxShadow = "none";
        
        pnlLogin.style.display = 'block';
        pnlReg.style.display = 'none';
        pnlSuccess.style.display = 'none';
      } else {
        btnReg.style.backgroundColor = "var(--surface-color)";
        btnReg.style.color = "var(--primary-color)";
        btnReg.style.boxShadow = "var(--shadow-sm)";
        btnLogin.style.backgroundColor = "transparent";
        btnLogin.style.color = "var(--text-muted)";
        btnLogin.style.boxShadow = "none";
        
        pnlReg.style.display = 'block';
        pnlLogin.style.display = 'none';
        pnlSuccess.style.display = 'none';
      }
    }

    function handleGatewayLogin(e) {
      if (e) e.preventDefault();
      const name = document.getElementById('gt-login-username').value.trim();
      const phone = document.getElementById('gt-login-credential').value.trim();
      const errorDiv = document.getElementById('gateway-error');
      
      errorDiv.style.display = 'none';

      fetch('/api/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, phone })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          if (data.role === 'admin') {
            window.location.href = data.redirect;
          } else {
            // Unlock and load session details
            document.getElementById('gateway-auth-overlay').style.display = 'none';
            document.getElementById('main-homepage-content').style.display = 'block';
            setupFarmerSession(data.user, data.dashboardData);
          }
        } else {
          errorDiv.textContent = data.message;
          errorDiv.style.display = 'block';
        }
      });
    }

    function handleGatewayRegister(e) {
      if (e) e.preventDefault();
      const name = document.getElementById('gt-reg-name').value.trim();
      const location = document.getElementById('gt-reg-location').value.trim();
      const size = document.getElementById('gt-reg-size').value.trim();
      const phone = document.getElementById('gt-reg-phone').value.trim();
      const password = document.getElementById('gt-reg-password').value.trim();
      const email = document.getElementById('gt-reg-email').value.trim();
      const errorDiv = document.getElementById('gateway-error');

      errorDiv.style.display = 'none';

      fetch('/api/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, location, size, phone, password, email })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          document.getElementById('gt-panel-register').style.display = 'none';
          document.getElementById('gt-panel-success').style.display = 'block';
        } else {
          errorDiv.textContent = data.error;
          errorDiv.style.display = 'block';
        }
      });
    }

    function togglePasswordVisibility(fieldId) {
      const input = document.getElementById(fieldId);
      const eye = document.getElementById(fieldId + '-eye');
      if (input.type === "password") {
        input.type = "text";
        eye.className = "fa-solid fa-eye-slash";
      } else {
        input.type = "password";
        eye.className = "fa-solid fa-eye";
      }
    }

    // --- Dashboard Tabs Control ---
    function switchTab(tabName) {
      document.querySelectorAll('.fd-tab-item').forEach(item => {
        item.classList.remove('active');
      });
      document.getElementById('tab-' + tabName).classList.add('active');

      document.querySelectorAll('.fd-panel').forEach(panel => {
        panel.classList.remove('active');
      });
      document.getElementById('panel-' + tabName).classList.add('active');
    }

    // --- Live News Updates Carousel ---
    let currentNewsSlide = 0;
    let newsTimer = null;

    function startNewsCarousel() {
      stopNewsCarousel();
      const slides = document.querySelectorAll('.news-slide');
      if (slides.length === 0) return;

      newsTimer = setInterval(() => {
        slides[currentNewsSlide].classList.remove('active');
        currentNewsSlide = (currentNewsSlide + 1) % slides.length;
        slides[currentNewsSlide].classList.add('active');
      }, 5000);
    }

    function stopNewsCarousel() {
      if (newsTimer) {
        clearInterval(newsTimer);
        newsTimer = null;
      }
    }

    // --- Farmer Custom Session Setup & Dashboard UI Controls ---
    let loggedFarmer = null;

    function setupFarmerSession(user, data) {
      loggedFarmer = { user, data };
      localStorage.setItem('loggedFarmer', JSON.stringify(loggedFarmer));
      
      // Update session header variables
      document.getElementById('header-profile-name').textContent = loggedFarmer.user.name;
      
      // Reveal docked dashboard link & profile log out badge
      document.getElementById('nav-dashboard-link').style.display = 'inline-block';
      document.getElementById('header-profile-badge').style.display = 'flex';
    }

    function openFarmerDashboard(e) {
      if (e) e.preventDefault();
      
      const cached = localStorage.getItem('loggedFarmer');
      if (cached) {
        loggedFarmer = JSON.parse(cached);
      } else {
        document.getElementById('main-homepage-content').style.display = 'none';
        document.getElementById('gateway-auth-overlay').style.display = 'flex';
        switchGatewayTab('login');
        return;
      }

      // Populate dashboard values
      document.getElementById('fd-welcome-title').textContent = loggedFarmer.user.name;
      document.getElementById('fd-location').textContent = loggedFarmer.user.location;
      document.getElementById('fd-size').textContent = loggedFarmer.user.size;
      document.getElementById('fd-footer-username').textContent = loggedFarmer.user.name;
      
      const photoPath = loggedFarmer.user.profile_photo || '/images/onboarding_welcome.jpg';
      document.getElementById('fd-header-avatar').src = photoPath;
      document.getElementById('fd-profile-avatar').src = photoPath;

      const w = loggedFarmer.data ? loggedFarmer.data.weather : { alert: "Soil Saturation Warning", forecast: "Continuous rainfall", temp: "29°C" };
      document.getElementById('fd-weather-desc').textContent = w.alert;
      document.getElementById('fd-weather-forecast').textContent = `Forecast: ${w.forecast} (${w.temp})`;
      
      document.getElementById('fd-pest-warning-count').textContent = '3 Active Alerts';

      // Load Profile form fields
      document.getElementById('prof-name').value = loggedFarmer.user.name;
      document.getElementById('prof-location').value = loggedFarmer.user.location;
      document.getElementById('prof-size').value = loggedFarmer.user.size;
      document.getElementById('prof-email').value = loggedFarmer.user.email || '';

      // Populate badges & history
      updateBadgesUI(loggedFarmer.user.badges);
      renderQueriesHistory(loggedFarmer.user.queries);

      // Open layout overlay & start slideshow
      document.getElementById('farmer-dashboard-overlay').classList.add('active');
      switchTab('feed');
      startNewsCarousel();
    }

    function openFarmerDashboardDiagnostic(e) {
      if (e) e.preventDefault();
      openFarmerDashboard();
      switchTab('diag');
    }

    function updateBadgesUI(badgesArray) {
      document.querySelectorAll('.badge-card').forEach(card => card.classList.remove('unlocked'));
      let count = 0;
      if (badgesArray) {
        badgesArray.forEach(badge => {
          count++;
          if (badge.includes("Saver")) document.getElementById('badge-saver').classList.add('unlocked');
          if (badge.includes("Watcher")) document.getElementById('badge-market').classList.add('unlocked');
          if (badge.includes("Doctor") && !badge.includes("Farm")) document.getElementById('badge-soil').classList.add('unlocked');
          if (badge.includes("Farm")) document.getElementById('badge-doctor').classList.add('unlocked');
        });
      }
      document.getElementById('fd-badges-unlocked-count').textContent = `${count} Unlocked`;
    }

    function renderQueriesHistory(queriesArray) {
      const container = document.getElementById('fd-history-list');
      if (!queriesArray || queriesArray.length === 0) {
        container.innerHTML = `<div style="text-align: center; color: var(--text-muted); font-size: 13px; padding: 20px;">No past calculations recorded.</div>`;
        return;
      }

      let html = "";
      queriesArray.slice().reverse().forEach(q => {
        html += `
          <div class="history-item">
            <div>
              <strong style="font-size: 14px;">${q.type}</strong>
              <div style="font-size: 12px; color: var(--text-muted);">${q.input} &rarr; ${q.result}</div>
            </div>
            <div style="font-size: 11px; color: var(--text-muted);">${q.date}</div>
          </div>
        `;
      });
      container.innerHTML = html;
    }

    function closeFarmerDashboard() {
      document.getElementById('farmer-dashboard-overlay').classList.remove('active');
      stopNewsCarousel();
    }

    function logoutFarmer() {
      loggedFarmer = null;
      localStorage.removeItem('loggedFarmer');
      window.location.reload();
    }

    // --- Profile Editing Submit Handlers ---
    function handleProfileUpdate(e) {
      if (e) e.preventDefault();
      const name = document.getElementById('prof-name').value.trim();
      const location = document.getElementById('prof-location').value.trim();
      const size = document.getElementById('prof-size').value.trim();
      const email = document.getElementById('prof-email').value.trim();
      const successDiv = document.getElementById('profile-edit-success');

      successDiv.style.display = 'none';

      fetch('/api/profile/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          phone: loggedFarmer.user.phone,
          name, location, size, email
        })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          loggedFarmer.user = data.user;
          localStorage.setItem('loggedFarmer', JSON.stringify(loggedFarmer));
          
          document.getElementById('fd-welcome-title').textContent = data.user.name;
          document.getElementById('fd-location').textContent = data.user.location;
          document.getElementById('fd-size').textContent = data.user.size;
          document.getElementById('fd-footer-username').textContent = data.user.name;
          document.getElementById('header-profile-name').textContent = data.user.name;
          
          updateBadgesUI(data.user.badges);

          successDiv.style.display = 'block';
          setTimeout(() => successDiv.style.display = 'none', 4000);
        }
      });
    }

    // --- Password change handler ---
    function handlePasswordChange(e) {
      if (e) e.preventDefault();
      const currentPassword = document.getElementById('pass-current').value.trim();
      const newPassword = document.getElementById('pass-new').value.trim();
      const successDiv = document.getElementById('password-change-success');
      const errorDiv = document.getElementById('password-change-error');

      successDiv.style.display = 'none';
      errorDiv.style.display = 'none';

      fetch('/api/profile/password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          phone: loggedFarmer.user.phone,
          currentPassword, newPassword
        })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          loggedFarmer.user.password = newPassword;
          localStorage.setItem('loggedFarmer', JSON.stringify(loggedFarmer));
          
          document.getElementById('profile-password-form').reset();
          successDiv.style.display = 'block';
          setTimeout(() => successDiv.style.display = 'none', 4000);
        } else {
          errorDiv.textContent = data.error;
          errorDiv.style.display = 'block';
        }
      });
    }

    // --- Profile Photo Uploading ---
    function triggerPhotoUpload() {
      document.getElementById('profile-photo-input').click();
    }

    function handlePhotoUpload(input) {
      if (input.files && input.files[0]) {
        const file = input.files[0];
        const status = document.getElementById('photo-upload-status');
        status.textContent = "Uploading profile photo...";

        const formData = new FormData();
        formData.append('profile_photo', file);
        formData.append('phone', loggedFarmer.user.phone);

        fetch('/api/profile/upload-photo', {
          method: 'POST',
          body: formData
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            loggedFarmer.user.profile_photo = data.photoPath;
            localStorage.setItem('loggedFarmer', JSON.stringify(loggedFarmer));
            
            document.getElementById('fd-header-avatar').src = data.photoPath;
            document.getElementById('fd-profile-avatar').src = data.photoPath;
            status.textContent = "Upload complete! Avatar updated.";
            setTimeout(() => status.textContent = "Tap image to upload new profile photo", 3000);
          } else {
            status.textContent = "Upload failed. Try again.";
          }
        });
      }
    }

    // --- AI Plant Disease Diagnosis ---
    let selectedDiagImgSrc = "";

    function previewDiagImage(input) {
      if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
          selectedDiagImgSrc = e.target.result;
          document.getElementById('diag-preview-img').src = selectedDiagImgSrc;
          document.getElementById('diag-preview-container').style.display = 'block';
        }
        reader.readAsDataURL(input.files[0]);
      }
    }

    function cancelDiagUpload() {
      document.getElementById('diag-file').value = "";
      document.getElementById('diag-preview-container').style.display = 'none';
      selectedDiagImgSrc = "";
    }

    function handlePlantDiagnosis(e) {
      if (e) e.preventDefault();
      const crop = document.getElementById('diag-crop').value;
      const fileInput = document.getElementById('diag-file');
      
      if (!fileInput.files || fileInput.files.length === 0) {
        alert("Please select a leaf photo first.");
        return;
      }

      document.getElementById('diag-results').style.display = 'none';
      document.getElementById('diag-progress-container').style.display = 'block';
      const statusText = document.getElementById('diag-scan-status');
      statusText.style.display = 'block';
      statusText.textContent = "Uploading crop scan...";

      const progressBar = document.getElementById('diag-progress');
      progressBar.style.width = "0%";

      let pWidth = 0;
      const interval = setInterval(() => {
        pWidth += 10;
        progressBar.style.width = pWidth + "%";
        
        if (pWidth === 30) statusText.textContent = "Scanning agricultural disease library...";
        if (pWidth === 70) statusText.textContent = "Comparing matching verified case logs...";
        
        if (pWidth >= 100) {
          clearInterval(interval);
          submitDiagRequest();
        }
      }, 250);

      function submitDiagRequest() {
        const formData = new FormData();
        formData.append('plant_photo', fileInput.files[0]);
        formData.append('crop', crop);
        formData.append('phone', loggedFarmer.user.phone);

        fetch('/api/diagnose', {
          method: 'POST',
          body: formData
        })
        .then(res => res.json())
        .then(data => {
          document.getElementById('diag-progress-container').style.display = 'none';
          statusText.style.display = 'none';

          if (data.success) {
            document.getElementById('diag-res-user-img').src = selectedDiagImgSrc;
            document.getElementById('diag-res-match-img').src = data.matchedCaseImage;
            document.getElementById('diag-res-pathogen').textContent = data.diagnosis;
            document.getElementById('diag-res-severity').textContent = data.severity;
            document.getElementById('diag-res-treatment').innerHTML = data.cure.replace(/\. /g, '.<br>&bull; ');
            document.getElementById('diag-match-score').textContent = data.matchScore;

            const badge = document.getElementById('diag-res-severity');
            if (data.severity.toLowerCase() === 'severe') {
              badge.style.backgroundColor = "rgba(220, 53, 69, 0.15)";
              badge.style.color = "#dc3545";
            } else if (data.severity.toLowerCase() === 'high') {
              badge.style.backgroundColor = "rgba(255, 193, 7, 0.15)";
              badge.style.color = "#FFC107";
            } else {
              badge.style.backgroundColor = "rgba(40, 167, 69, 0.15)";
              badge.style.color = "#28a745";
            }

            document.getElementById('diag-results').style.display = 'block';
            fetchQueriesUpdate();
          }
        });
      }
    }

    function fetchQueriesUpdate() {
      fetch('/api/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: loggedFarmer.user.name, phone: loggedFarmer.user.phone })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          loggedFarmer.user = data.user;
          localStorage.setItem('loggedFarmer', JSON.stringify(loggedFarmer));
          updateBadgesUI(data.user.badges);
          renderQueriesHistory(data.user.queries);
        }
      });
    }

    // --- Support Chatbot Desk Simulation ---
    function sendChatMessage() {
      const input = document.getElementById('chat-input');
      const text = input.value.trim();
      if (text === "") return;

      const chatBox = document.getElementById('help-chat-box');

      const userBubble = document.createElement('div');
      userBubble.style.alignSelf = "flex-end";
      userBubble.style.backgroundColor = "var(--primary-color)";
      userBubble.style.color = "#FFF";
      userBubble.style.padding = "12px 16px";
      userBubble.style.borderRadius = "var(--border-radius-sm)";
      userBubble.style.maxWidth = "80%";
      userBubble.style.fontSize = "13.5px";
      userBubble.innerHTML = `<strong>You:</strong> ${text}`;
      chatBox.appendChild(userBubble);

      input.value = "";
      chatBox.scrollTop = chatBox.scrollHeight;

      setTimeout(() => {
        const botBubble = document.createElement('div');
        botBubble.style.alignSelf = "flex-start";
        botBubble.style.backgroundColor = "#FFF";
        botBubble.style.padding = "12px 16px";
        botBubble.style.borderRadius = "var(--border-radius-sm)";
        botBubble.style.border = "1px solid var(--border-color)";
        botBubble.style.maxWidth = "80%";
        botBubble.style.fontSize = "13.5px";

        let reply = "Thank you for reaching out. An agricultural advisor has been notified of your question and will reply via SMS text shortly.";
        const lowText = text.toLowerCase();
        
        if (lowText.includes("crop") || lowText.includes("plant") || lowText.includes("seed")) {
          reply = "For crop advice, you can use our <strong>AI Diagnose</strong> tab to upload a leaf scan, or check our <strong>Suggested Seeds</strong> listed in the main feed tab!";
        } else if (lowText.includes("weather") || lowText.includes("rain")) {
          reply = "The current weather reports suggest rainfall changes. You can view your local <strong>Live Climate Threat Alert</strong> under the main Feed tab.";
        } else if (lowText.includes("password") || lowText.includes("profile")) {
          reply = "You can modify your name, location, password, or upload a new photo directly under the <strong>Profile & Badges</strong> tab in this window.";
        }

        botBubble.innerHTML = `<strong>Seedorra Assistant:</strong> ${reply}`;
        chatBox.appendChild(botBubble);
        chatBox.scrollTop = chatBox.scrollHeight;
      }, 1000);
    }

    // --- Agronomy Advisory Utilities ---
    function getRecommendation() {
      const state = document.getElementById('crop-state').value;
      const season = document.getElementById('crop-season').value;
      const resultsDiv = document.getElementById('crop-results');
      const resultsText = document.getElementById('crop-results-text');
      
      let crops = "";
      if (season === 'wet') {
        crops = "🌱 <strong>Cassava (Gari)</strong>: Best for wet season planting. High soil adaptability.\n" +
                "🌽 <strong>Maize (White/Yellow)</strong>: Immediate high yield potential. Plant early in wet season.\n" +
                "🌾 <strong>Rice (Ofada/Local)</strong>: Ideal for swampland and flooded fields.";
      } else {
        crops = "🧅 <strong>Onions & Garlic</strong>: High profit margin in dry season. Needs moderate drip irrigation.\n" +
                "🍅 <strong>Tomatoes</strong>: Excellent dry season yield. Low disease susceptibility in low humidity.\n" +
                "🥔 <strong>Sweet Potato</strong>: Drought resistant. Requires minimal tilling and holds moisture.";
      }
      
      resultsText.innerHTML = crops.replace(/\n/g, '<br>');
      resultsDiv.style.display = 'block';

      awardBadgeSilently("Market Watcher");
    }

    function getPlantingCalendar() {
      const crop = document.getElementById('calendar-crop').value;
      const resultsDiv = document.getElementById('calendar-results');
      const resultsText = document.getElementById('calendar-results-text');
      
      const calendar = {
        maize: "📅 <strong>Best Sowing Window</strong>: Early April - Mid May (Main Wet Season). 2nd crop can be planted in late August.",
        rice: "📅 <strong>Best Sowing Window</strong>: May - June (requires steady water logging) or nursery prep in late April.",
        cassava: "📅 <strong>Best Sowing Window</strong>: April - June (best stem establishment period). Can cultivate year-round with irrigation.",
        yam: "📅 <strong>Best Sowing Window</strong>: November - February (dry season heap preparation) or early rainy season planting (March).",
        beans: "📅 <strong>Best Sowing Window</strong>: Late August - September (late rain period prevents pod rotting)."
      };

      resultsText.innerHTML = calendar[crop];
      resultsDiv.style.display = 'block';
      
      awardBadgeSilently("Market Watcher");
    }

    function calculateYield() {
      const crop = document.getElementById('yield-crop').value;
      const size = parseFloat(document.getElementById('yield-size').value) || 0;
      const resultsDiv = document.getElementById('yield-results');
      const resultsText = document.getElementById('yield-results-text');
      
      if (size <= 0) {
        resultsText.textContent = "Please enter a valid farm size.";
        resultsDiv.style.display = 'block';
        return;
      }

      const yields = {
        maize: { bags: 45, unit: "bags (50kg)" },
        rice: { bags: 80, unit: "bags (50kg)" },
        cassava: { bags: 260, unit: "bags (fresh roots)" },
        yam: { bags: 400, unit: "tubers (large)" }
      };

      const rate = yields[crop].bags;
      const total = Math.round(rate * size);
      
      resultsText.innerHTML = `🌾 Your estimated yield for <strong>${size} Hectares</strong> is:<br><span style="font-size: 24px; font-weight: 800; color: var(--primary-color);">${total.toLocaleString()}</span> ${yields[crop].unit}.`;
      resultsDiv.style.display = 'block';
    }

    function awardBadgeSilently(badgeName) {
      if (loggedFarmer) {
        if (!loggedFarmer.user.badges.includes(badgeName)) {
          fetch('/api/profile/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              phone: loggedFarmer.user.phone,
              name: loggedFarmer.user.name,
              location: loggedFarmer.user.location,
              size: loggedFarmer.user.size,
              email: loggedFarmer.user.email || ""
            })
          })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              fetchQueriesUpdate();
            }
          });
        }
      }
    }

    // --- GATEWAY ORCHESTRATION ON STARTUP ---
    window.addEventListener('DOMContentLoaded', () => {
      // Support visual customize dashboard previews
      const showDashboardPreview = <%= showDashboard %>;
      if (showDashboardPreview) {
        document.getElementById('main-homepage-content').style.display = 'block';
        setupFarmerSession({
          name: "Preview Farmer",
          location: "Oyo, Nigeria",
          size: "4.5",
          phone: "08000000000",
          badges: ["Seedling Saver", "Market Watcher", "Farm Doctor"],
          queries: [
            { type: "Crop Advice", input: "Wet Season", result: "Cassava, Maize", date: "18 Jul 2026" }
          ]
        }, {
          weather: { alert: "Oyo Flood Alert", forecast: "Heavy rainfall", temp: "30°C" }
        });
        openFarmerDashboard();
        return;
      }

      const cached = localStorage.getItem('loggedFarmer');
      
      if (cached) {
        document.getElementById('main-homepage-content').style.display = 'block';
        const parsed = JSON.parse(cached);
        setupFarmerSession(parsed.user, parsed.data);
      } else {
        const showOnboarding = <%= showOnboarding %>;
        if (showOnboarding) {
          document.getElementById('onboarding-overlay').style.display = 'flex';
          startOnboardingTimer();
        } else {
          document.getElementById('gateway-auth-overlay').style.display = 'flex';
          switchGatewayTab('login');
        }
      }
    });
  </script>
</body>
</html>
