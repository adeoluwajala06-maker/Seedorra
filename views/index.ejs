                <div class="badge-card unlocked" id="badge-saver" title="Unlocked upon registering your farm layout.">
                  <div class="badge-icon">🏅</div>
                  <div style="font-weight: 700; font-size: 12px;">Seedling Saver</div>
                  <div style="font-size: 10px; color: var(--text-muted); margin-top: 4px;">Registered Farm</div>
                </div>
                <!-- Market Watcher -->
                <div class="badge-card" id="badge-market" title="Awarded for checking live regional pricing.">
                  <div class="badge-icon">🏆</div>
                  <div style="font-weight: 700; font-size: 12px;">Market Watcher</div>
                  <div style="font-size: 10px; color: var(--text-muted); margin-top: 4px;">Price Checker</div>
                </div>
                <!-- Soil Doctor -->
                <div class="badge-card" id="badge-soil" title="Awarded for updating profile stats or generating soil logs.">
                  <div class="badge-icon">🌟</div>
                  <div style="font-weight: 700; font-size: 12px;">Soil Doctor</div>
                  <div style="font-size: 10px; color: var(--text-muted); margin-top: 4px;">Soil Restorer</div>
                </div>
                <!-- Farm Doctor -->
                <div class="badge-card" id="badge-doctor" title="Unlocked by analyzing diseased leaf scans.">
                  <div class="badge-icon">🩺</div>
                  <div style="font-weight: 700; font-size: 12px;">Farm Doctor</div>
                  <div style="font-size: 10px; color: var(--text-muted); margin-top: 4px;">Plant Diagnosed</div>
                </div>
              </div>

              <h3 style="margin-bottom: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 8px;">Past Queries Log</h3>
              <div class="history-list" id="fd-history-list">
                <div class="history-item">
                  <div>
                    <strong style="font-size: 14px;">Crop Recommendation</strong>
                    <div style="font-size: 12px; color: var(--text-muted);">Wet Season, Oyo State</div>
                  </div>
                  <div style="font-size: 11px; color: var(--text-muted);">17 Jul 2026</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- PANEL 5: HELP DESK -->
        <div class="fd-panel" id="panel-help">
          <h3 style="margin-bottom: 8px;">Seedorra Self-Help & Customer Desk</h3>
          <p style="font-size: 14px; color: var(--text-muted); margin-bottom: 24px;">Chat live with our mock agronomy assistant or reach customer care support representatives.</p>

          <div style="border: 1px solid var(--border-color); border-radius: var(--border-radius-md); overflow: hidden; display: flex; flex-direction: column; height: 380px; background-color: var(--bg-color);">
            <!-- Chat history -->
            <div style="flex-grow: 1; padding: 20px; overflow-y: auto; display: flex; flex-direction: column; gap: 12px;" id="help-chat-box">
              <div style="align-self: flex-start; background-color: #FFF; padding: 12px 16px; border-radius: var(--border-radius-sm); border: 1px solid var(--border-color); max-width: 80%; font-size: 13.5px;">
                <strong>Seedorra Assistant:</strong> Hello! How can I help you today? Ask me about crop planting, pest treatments, or updating your profile!
              </div>
            </div>
            
            <!-- Chat Input bar -->
            <div style="padding: 12px; background-color: #FFF; border-top: 1px solid var(--border-color); display: flex; gap: 12px;">
              <input type="text" id="chat-input" class="form-control" placeholder="Type your support query here..." onkeyup="if(event.key === 'Enter') sendChatMessage()">
              <button class="btn btn-primary" onclick="sendChatMessage()" style="padding: 0 24px;"><i class="fa-solid fa-paper-plane"></i></button>
            </div>
          </div>
          
          <div style="margin-top: 24px; display: flex; gap: 16px; align-items: center; justify-content: space-between; background-color: rgba(140, 98, 255, 0.04); border: 1px solid rgba(140, 98, 255, 0.1); border-radius: var(--border-radius-md); padding: 20px;">
            <div>
              <h4 style="font-size: 15px; color: var(--primary-color);">Need support?</h4>
              <p style="font-size: 13px; color: var(--text-muted); margin-top: 2px;">Toll-free customer line: <strong>080073336772</strong>.</p>
            </div>
            <a href="tel:080073336772" class="btn btn-secondary" style="font-size: 13px; padding: 10px 20px;"><i class="fa-solid fa-phone" style="margin-right: 8px;"></i>Call Support</a>
          </div>
        </div>

      </div>

      <!-- Dashboard Global Navigation Footer -->
      <div style="padding: 16px 32px; background-color: var(--bg-color); border-top: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center; z-index: 10;">
        <span style="font-size: 12px; color: var(--text-muted);"><i class="fa-solid fa-circle-check" style="color: var(--secondary-color); margin-right: 6px;"></i>Logged in as <span style="font-weight: 700; color: var(--text-main);" id="fd-footer-username">Farmer</span></span>
        <div style="display: flex; gap: 12px;">
          <button class="btn btn-secondary" style="padding: 8px 18px; font-size: 14px;" onclick="closeFarmerDashboard()"><i class="fa-solid fa-angles-down" style="margin-right: 6px;"></i>Minimize Dashboard</button>
          <button class="btn btn-primary" style="padding: 8px 18px; font-size: 14px;" onclick="closeFarmerDashboard()"><i class="fa-solid fa-arrow-left-long" style="margin-right: 8px;"></i>Back to Home Page</button>
        </div>
      </div>

    </div>
  </div>

  <!-- MAIN HOMEPAGE CONTENT WRAPPER -->
  <div id="main-homepage-content" style="display: none;">
    <!-- Header -->
    <header>
      <div class="container nav-wrapper">
        <a href="/" class="logo-link">
          <div class="logo-icon">S</div>
          <%= site_name %>
        </a>
        
        <nav id="nav-menu">
          <a href="#home" class="active"><%= dict.nav_home %></a>
          <a href="#prices"><%= dict.nav_prices %></a>
          <a href="#tools"><%= dict.nav_tools %></a>
          
          <!-- Docked Dashboard Navigation tab item (only shown when logged in) -->
          <a href="#" id="nav-dashboard-link" style="display: none; font-weight: 700; color: var(--accent-color);" onclick="openFarmerDashboard(event)">
            <i class="fa-solid fa-gauge-high" style="margin-right: 6px;"></i>Dashboard
          </a>
          
          <span id="header-profile-badge" style="display: none; align-items: center; gap: 12px; margin-left: 12px; padding-left: 12px; border-left: 1px solid var(--border-color);">
